{
  "kind": "collectionType",
  "collectionName": "news",
  "info": {
    "singularName": "single-news",
    "pluralName": "news",
    "displayName": "news",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "text",
      "required": true,
      "unique": true
    },
    "heading": {
      "type": "text"
    },
    "content": {
      "type": "richtext"
    },
    "authName": {
      "type": "string",
      "default": "By CXO Team"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "Date": {
      "type": "date",
      "required": false
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "videoUrl": {
      "type": "string"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "news"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "news"
    },
    "subcategories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::subcategory.subcategory",
      "inversedBy": "news"
    },
    "description": {
      "type": "text"
    },
    "keywords": {
      "type": "text"
    }
  }
}
